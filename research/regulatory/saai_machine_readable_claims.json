        "langgraph_wrapper": "full — per-invoke fidelity + AgenticDriftTracker + governance_trace trajectory",
        "langgraph_swarm": "full — per-handoff fidelity + SCI chain tracking + AgenticDriftTracker graduated sanctions",
        "langgraph_supervisor": "partial — per-delegation fidelity only; no drift tracker or SCI chain tracking",
        "openclaw_daemon": "full (volatile) — per-call fidelity + AgenticDriftTracker + CUSUM; state lost on daemon restart",
