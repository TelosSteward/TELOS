# TELOS Observatory (PRIVATE REPO) - .gitignore

# ============================================================
# SECRETS - NEVER COMMIT
# ============================================================
.env
*.env
.env.local
.env.production
*_API_KEY*
*_api_key*
.mistral_api_key
.openai_api_key
credentials.json
secrets/
*.pem
*.key
.mcp.json

# ============================================================
# USER DATA - PRIVACY COMPLIANCE
# ============================================================
# Beta consent forms (contain user information)
telos_observatory_v3/beta_consents/*.json
!telos_observatory_v3/beta_consents/.gitkeep

# Session data (user conversations)
sessions/
saved_sessions/
test_sessions/*.json

# Runtime session files
.telos_active_session.json
.telos_session_pa.json
.telos_session_log.json
.telos_checkpoint_*.json
.telos_current_turn.json
.telos_export_instruction.json
session_export_*.json
.runtime_governance_session.json
.runtime_governance_checkpoint_*.json

# User databases
*.db
*.sqlite
*.sqlite3

# Logs with potential PII
logs/
*.log
phase2_*.log

# ============================================================
# BUILD & DEPENDENCIES
# ============================================================
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.pixi/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

