.envrc

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# Ruff
.ruff_cache/

# PyPI configuration
.pypirc

# Cursor IDE
.cursorignore
.cursorindexingignore

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/

# Abstra
.abstra/

# ============================================================
# IDE & OS
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# TELOS-SPECIFIC OUTPUTS
# ============================================================
# Phase 2 validation data
telos_observatory/phase2_study_results/
telos_observatory/phase2_validation_*/
telos_observatory/phase2b_continuous_*/

# Quality reports
**/quality_analysis_report.md

# Test output
test_output/

# Temporary files
*.tmp
temp/
tmp/

# Generated exports
docs/sanitized_public_repo/

# ============================================================
# STREAMLIT
# ============================================================
.streamlit/secrets.toml
.streamlit/config.toml

# ============================================================
# DOCUMENTATION DRAFTS (keep published docs)
# ============================================================
# Keep: README.md, docs/*.md (published)
# Exclude: grant_draft_*.md, internal_notes.md
grant_draft_*.md
internal_notes.md
strategy_*.md
partnership_*.md

# ============================================================
# ARCHIVES - LOCAL ONLY (rollback safety)
# ============================================================
.archive/
PRE_OPUS_AUDIT/
pre_opus_audit_*