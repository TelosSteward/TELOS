# TELOS Observatory Streamlit Secrets Template
# Copy this to secrets.toml and fill in your actual values
# NEVER commit secrets.toml to version control

# Mistral API (required for LLM functionality)
MISTRAL_API_KEY = "your-mistral-api-key-here"

# Backend Data Infrastructure (optional - for delta storage)
# Configure your own backend service for governance metric storage
# BACKEND_URL = "https://your-backend-service.example.com"
# BACKEND_KEY = "your-backend-api-key-here"

# Optional: Anthropic API for model comparisons
# ANTHROPIC_API_KEY = "your-anthropic-key-here"
