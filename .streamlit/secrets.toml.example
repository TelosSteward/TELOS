# Streamlit Secrets Configuration - EXAMPLE FILE
# Copy this to secrets.toml and add your actual API keys
# DO NOT COMMIT secrets.toml TO VERSION CONTROL

[default]
# Mistral API Key for LLM generation (REQUIRED)
# Get your key from: https://console.mistral.ai/
MISTRAL_API_KEY = "your-mistral-api-key-here"

# Optional: Other API keys
# OPENAI_API_KEY = "your-openai-api-key-here"
# ANTHROPIC_API_KEY = "your-anthropic-api-key-here"

# Beta testing configuration (optional - has defaults)
[beta]
enabled = true
data_dir = "beta_testing/data"
min_turns_for_completion = 50
beta_duration_days = 14
