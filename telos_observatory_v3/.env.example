# TELOS Observatory Environment Variables
# Copy this to .env and fill in your actual values

# Backend Data Infrastructure (configure your own)
# BACKEND_URL=https://your-backend-service.example.com
# BACKEND_KEY=your-backend-api-key-here

# Mistral API
MISTRAL_API_KEY=your-mistral-api-key-here

# Optional: Anthropic API for comparisons
ANTHROPIC_API_KEY=your-anthropic-key-here
