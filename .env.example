# TELOS Observatory Environment Configuration
# Copy this file to .env and fill in your actual API key

# Mistral AI API (Required for TELOS core functionality AND Steward research analysis)
# Get your key from: https://console.mistral.ai/
# This single API key powers:
#   - TELOS governance system
#   - Steward AI research analysis
#   - All conversational interactions
MISTRAL_API_KEY=your-mistral-api-key-here

# Optional: Additional configuration
# TELOS_DEBUG=false
# TELOS_LOG_LEVEL=INFO
