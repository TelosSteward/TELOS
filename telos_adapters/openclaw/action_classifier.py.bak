# Build case-insensitive lookup: maps lowercased name -> (group, telos_name)
_TOOL_MAP_CI: Dict[str, Tuple[str, str]] = {
    k.lower(): v for k, v in _OPENCLAW_TOOL_MAP_RAW.items()
}

# Maps string risk_level from YAML config to ToolGroupRiskTier enum.
# Used by ActionClassifier when per-tool risk overrides group-level risk.
_RISK_LEVEL_MAP: Dict[str, ToolGroupRiskTier] = {
    "low": ToolGroupRiskTier.LOW,
    "medium": ToolGroupRiskTier.MEDIUM,
    "high": ToolGroupRiskTier.HIGH,
    "critical": ToolGroupRiskTier.CRITICAL,
}

# Public reference (canonical casing preserved for iteration/export)
OPENCLAW_TOOL_MAP: Dict[str, Tuple[str, str]] = _OPENCLAW_TOOL_MAP_RAW


def _lookup_tool(tool_name: str) -> Optional[Tuple[str, str]]:
    """Case-insensitive tool name lookup."""
    # Try exact match first (fast path)
    result = _OPENCLAW_TOOL_MAP_RAW.get(tool_name)
    if result:
        return result
    # Fall back to case-insensitive
    return _TOOL_MAP_CI.get(tool_name.lower())


@dataclass
class ClassifiedAction:
    """Result of classifying an OpenClaw tool call."""
    openclaw_tool_name: str
    tool_group: str
    telos_tool_name: str
    risk_tier: ToolGroupRiskTier
    is_cross_group: bool = False
    previous_group: Optional[str] = None


class ActionClassifier:
    """Maps OpenClaw tool calls to TELOS governance categories.

    Tracks tool group transitions for cross-group chain detection.
    The primary exfiltration pattern is cross-group: fs -> runtime -> web.

    Accepts an optional per-tool risk map (from YAML config tool definitions)
    to override group-level risk with more granular per-tool risk_level.
    """

    def __init__(self, tool_risk_overrides: Optional[Dict[str, str]] = None):
        """Initialize the action classifier.

        Args:
            tool_risk_overrides: Optional mapping of telos_tool_name -> risk_level
                from the YAML config tool definitions. When present, per-tool
                risk_level takes precedence over group-level risk.
        """
        self._previous_group: Optional[str] = None
        self._chain_groups: list = []
        self._tool_risk_overrides = tool_risk_overrides or {}

    def classify(self, tool_name: str) -> ClassifiedAction:
        """Classify an OpenClaw tool call.

        Uses case-insensitive lookup. Per-tool risk_level from YAML config
        overrides group-level risk when available.

        Args:
            tool_name: The OpenClaw tool name from before_tool_call event.

        Returns:
            ClassifiedAction with group, TELOS name, risk tier, and
            cross-group flag.
        """
        mapping = _lookup_tool(tool_name)

        if mapping:
            group, telos_name = mapping
        else:
            # Unknown tool — classify as openclaw group (CRITICAL)
            # with the original name preserved
            group = "openclaw"
            telos_name = f"openclaw_{tool_name.lower()}"
            logger.warning(
                f"Unknown OpenClaw tool '{tool_name}' — classified as "
                f"group:openclaw (CRITICAL)"
            )

        # Per-tool risk from YAML config overrides group-level risk
        tool_risk_str = self._tool_risk_overrides.get(telos_name)
        if tool_risk_str:
            risk_tier = _RISK_LEVEL_MAP.get(
                tool_risk_str, TOOL_GROUP_RISK_MAP.get(group, ToolGroupRiskTier.CRITICAL)
            )
        else:
            risk_tier = TOOL_GROUP_RISK_MAP.get(group, ToolGroupRiskTier.CRITICAL)

        # Cross-group detection
        is_cross_group = (
            self._previous_group is not None
            and self._previous_group != group
        )

        result = ClassifiedAction(
            openclaw_tool_name=tool_name,
            tool_group=group,
            telos_tool_name=telos_name,
            risk_tier=risk_tier,
            is_cross_group=is_cross_group,
            previous_group=self._previous_group,
        )

        # Update state
        self._previous_group = group
        self._chain_groups.append(group)

        if is_cross_group:
            logger.info(
                f"Cross-group transition: {result.previous_group} -> {group} "
                f"(chain: {' -> '.join(self._chain_groups[-3:])})"
            )

        return result

    def reset_chain(self) -> None:
        """Reset chain tracking (new task/session)."""
        self._previous_group = None
        self._chain_groups.clear()

    @property
    def chain_length(self) -> int:
        """Current chain length."""
        return len(self._chain_groups)

    @property
    def chain_groups(self) -> list:
        """Tool groups in current chain."""
        return list(self._chain_groups)

    @staticmethod
    def get_risk_tier(group: str) -> ToolGroupRiskTier:
        """Get the risk tier for a tool group."""
        return TOOL_GROUP_RISK_MAP.get(group, ToolGroupRiskTier.CRITICAL)
