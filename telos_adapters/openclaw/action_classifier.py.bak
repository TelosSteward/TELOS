"""
Action Classifier — Maps OpenClaw tool names to TELOS governance categories.

OpenClaw exposes 10 tool groups, each with distinct risk profiles derived
from documented security incidents (CVE-2026-25253, ClawHavoc, Moltbook).

Risk tier mapping (M0 convergence point C3, unanimously agreed):
    CRITICAL: runtime, messaging, automation, openclaw
    HIGH:     fs, web
    MEDIUM:   nodes
    LOW:      sessions, memory, ui

Cross-group chain detection: When consecutive tool calls span different
groups, the classifier flags this for SCI chain tracking. The primary
exfiltration pattern (ClawHavoc, Moltbook) is: read creds (fs) -> exec
curl (runtime) -> exfiltrate (web/messaging). Cross-group transitions
between HIGH+ groups trigger elevated scoring.

Regulatory traceability:
    - EU AI Act Art. 9: Risk tiers implement graduated risk management
    - SAAI claim TELOS-SAAI-010: Tool group risk tiering (11 groups × 4 tiers)
    - SAAI claim TELOS-SAAI-013: ClawHavoc-sourced supply chain detection
    - SAAI claim TELOS-SAAI-014: Cross-group chain detection and escalation
    - NIST AI RMF MAP 3.1: Supply chain risk mapping via tool classification
    - OWASP ASI03 (Privilege Abuse): Cross-group escalation detection
    - OWASP ASI04 (Supply Chain): Shadow tool and poisoning pattern detection
    See: research/openclaw_regulatory_mapping.md §2, §6
"""

import logging
from dataclasses import dataclass
from enum import Enum
from typing import Dict, Optional, Tuple

logger = logging.getLogger(__name__)


class ToolGroupRiskTier(str, Enum):
    """Risk tier for OpenClaw tool groups.

    Derived from documented CVEs and security incidents.
    See: HANDOFF_OPENCLAW.md §4 (Convergence Point C3).

    EU AI Act Art. 9 compliance: Risk tiers map governance depth to
    tool group risk, with CRITICAL groups receiving full cascade scoring
    and LOW groups receiving keyword-only screening.
    SAAI claim TELOS-SAAI-010.
    """
    CRITICAL = "critical"
    HIGH = "high"
    MEDIUM = "medium"
    LOW = "low"


# OpenClaw tool group -> risk tier mapping
# Source: Russell governance theory analysis + Karpathy systems assessment (M0)
TOOL_GROUP_RISK_MAP: Dict[str, ToolGroupRiskTier] = {
    "runtime": ToolGroupRiskTier.CRITICAL,
    "messaging": ToolGroupRiskTier.CRITICAL,
    "automation": ToolGroupRiskTier.CRITICAL,
    "openclaw": ToolGroupRiskTier.CRITICAL,
    "fs": ToolGroupRiskTier.HIGH,
    "web": ToolGroupRiskTier.HIGH,
    "nodes": ToolGroupRiskTier.MEDIUM,
    "sessions": ToolGroupRiskTier.LOW,
    "memory": ToolGroupRiskTier.LOW,
    "ui": ToolGroupRiskTier.LOW,
}

