{
  "name": "telos-governance",
  "version": "1.0.0",
  "description": "TELOS governance plugin for OpenClaw \u2014 scores every tool call through a 4-layer cascade (keyword, cosine, SetFit, LLM) with ~15ms latency",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openclaw",
    "governance",
    "telos",
    "security",
    "agent-governance"
  ],
  "author": "TELOS AI Labs Inc. <JB@telos-labs.ai>",
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "hooks": [
      "before_tool_call",
      "message_sending",
      "session_start",
      "session_end",
      "gateway_start",
      "gateway_stop"
    ]
  }
}
